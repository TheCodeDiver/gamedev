pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
	icrops()
	iplr()
	idays()
	trans()
end

function _update()
	uplr()
	uactions()
	udays()
end

function _draw()
	map()
	dplr()
	print(flr(clock),89,122,10)
	print(day,104,122,10)
	print(carrots,40,122,10)
	dtrans()
end

-->8
--player movement--

function iplr()
	plr={
		x=63,
		y=63
	}
end


function uplr()

	if btn(➡️) then
		plr.x+=1
	elseif btn(⬅️) then
		plr.x-=1
	end --if⬅️➡️
	
	if btn(⬆️) then
		plr.y-=1
	elseif btn(⬇️) then
		plr.y+=1
	end --if⬆️⬇️
	
	
	tile={
		x=flr((plr.x+6)/8),
		y=flr((plr.y+8)/8)
	}
end --uplr

function dplr()
	spr(4,tile.x*8,tile.y*8)
	spr(10,plr.x,plr.y)
end

-->8
--action btn ❎--

function uactions()
	if btnp(❎) then
		local sp=mget(tile.x,tile.y)
		
		if fget(sp,0) then
			mset(tile.x,tile.y,33)
		elseif fget(sp,1) then
			mset(tile.x,tile.y,sp+16)
		elseif fget(sp,3) then
			mset(tile.x,tile.y,52)
			harvest()
		elseif fget(sp,4) then
			day+=1
			clock=24
			trans()
			grow()
		end
	
	end
end
-->8
--day cycle--

function idays()
	day=1
	clock=24
end

function udays()
	clock-=.01
end

--transition--

function itrans()
	ttime=128
end

function trans()
	ttime=0
end

function dtrans()
	ttime+=6
	if ttime<128 then
		rectfill(0,0,128,128-ttime,1)
	end
end
-->8
--grow--

function grow()
 for tx=0,15 do
 	for ty=0,15 do
 		local sp=(mget(tx,ty))
 		if fget(sp,2) then
 			mset(tx,ty,sp-15)
 		end
 	end
 end
end
-->8
--inventory--

function icrops()
	carrots=0
	seeds=0
end

function harvest()
	carrots+=1
end
