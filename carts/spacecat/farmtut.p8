pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
	icrops()
	imoney()
	iplr()
	idays()
	trans()
	state="play"
end

function _update()
	if state=="play" then
		uplr()
		uactions()
		udays()
	elseif state=="dead" then
		if btnp(🅾️) then
			run()
		end
	end
end

function _draw()
	cls()
	if state=="play" then
		map()
		dplr()
		print(seeds,8,122,10)
		print(carrots,32,122,10)
		print(money,56,122,10)
		print(flr(plr.bat),80,122,10)
		print(flr(clock),105,122,10)
		print(day,120,122,10)
		dtrans()
	elseif state=="dead" then 
		print("you're dead lol, press 🅾️ to restart",20,50,10)
	end
end

-->8
--player movement--

function iplr()
	plr={
		x=63,
		y=63,
		bat=100
	}
end


function uplr()

	if btn(⬆️⬇️⬅️➡️) then
		drain("mv")
	end

	if btn(➡️) then
		plr.x+=1
	elseif btn(⬅️) then
		plr.x-=1
	end --if⬅️➡️
	
	if btn(⬆️) then
		plr.y-=1
	elseif btn(⬇️) then
		plr.y+=1
	end --if⬆️⬇️
	
	
	tile={
		x=flr((plr.x+6)/8),
		y=flr((plr.y+8)/8)
	}
end --uplr

function dplr()
	spr(4,tile.x*8,tile.y*8)
	spr(10,plr.x,plr.y)
end

-->8
--action btn ❎--

function uactions()
	if btnp(❎) then
		local sp=mget(tile.x,tile.y)
		
		--plant seeds
		if fget(sp,0) then
			if seeds>0 then
				mset(tile.x,tile.y,33)
				drain("act")
				seeds-=1
			end
		--water tile
		elseif fget(sp,1) then
			mset(tile.x,tile.y,sp+16)
			drain("act")
			
		--harvest carrot	
		elseif fget(sp,3) then
			mset(tile.x,tile.y,52)
			harvest()
			drain("act")
			
		--day progression
		elseif fget(sp,4) then
			day+=1
			clock=24
			trans()
			grow()
			plr.bat=100
			
		--buy seeds
		elseif fget(sp,5) then
			if money>0 then
				money-=1
				seeds+=1
			end	

		--sell carrots
		elseif fget(sp,5) then
			if carrots>0 then
				money+=3
				carrots-=1
			end
		end
	
	end
end
-->8
--day cycle--

function idays()
	day=1
	clock=24
end

function udays()
	clock-=.01
	if clock<0 then
		state="dead"
	end
end

--transition--

function itrans()
	ttime=128
end

function trans()
	ttime=0
end

function dtrans()
	ttime+=6
	if ttime<128 then
		rectfill(0,0,128,128-ttime,1)
	end
end
-->8
--grow--

function grow()
 for tx=0,15 do
 	for ty=0,15 do
 		local sp=(mget(tx,ty))
 		if fget(sp,2) then
 			mset(tx,ty,sp-15)
 		end
 	end
 end
end
-->8
--inventory--

function icrops()
	carrots=0
	seeds=0
end

function imoney()
	money=12
end

function harvest()
	carrots+=1
end
-->8
--battery--

function drain(amt)
	if amt=="mv" then
		plr.bat-=.10
	elseif amt=="act" then
		plr.bat-=.20
	end
	
	if plr.bat<0 then
		state="dead"
	end
end

