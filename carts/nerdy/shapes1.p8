pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
cls()

x1 = 40
y1 = 40
c1 = 8

x2 = 80
y2 = 80
c2 = 12

r = 15


--rectangles
rectfill(x1, y1, x2, y2, 11)
rect(x1, y1, x2, y2, 3)

--ovals
ovalfill(x1, y1, x2, y2, 9)
oval(x1, y1, x2, y2, 4)

--circles
circ(60, 60, r, 2)
circfill(60, 60, r, 8)

--lines
line( x1, y1, x2, y2, 7 )

--points
pset( x1, y1, c1)
pset( x2, y2, c2)


__gfx__
