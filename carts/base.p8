pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
	positionx=63
	positiony=63
end

function _update()
--player movement
	if btn(⬅️) then
		positionx-=1
	end
	if btn(➡️) then
		positionx+=1
	end
	if btn(⬆️) then
		positiony-=1
	end
	if btn(⬇️) then
		positiony+=1
	end
end

function _draw()
	cls()
	spr(1,positionx,positiony)
end
